# Normalize line endings so Windows checkouts do not dirty the tree.
* text=auto eol=lf

*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.luau text eol=lf
*.md   text eol=lf

# Roblox model and place files are binary; never diff or merge them.
*.rbxm  binary
*.rbxmx binary
*.rbxl  binary
*.rbxlx binary
*.png   binary
*.exe   binary

# --- GitHub language statistics (linguist) ---
# Only count real source. Docs, config, and generated output are excluded so the
# repo reports as TypeScript rather than Markdown/JSON.

*.md  linguist-documentation
*.txt linguist-documentation
LICENSE  linguist-documentation

*.json linguist-detectable=false

dist/**             linguist-generated=true
build/**            linguist-generated=true
bin/**              linguist-generated=true
package-lock.json   linguist-generated=true

# Luau in scaffolded templates is example content, not this tool's source.
*.luau linguist-detectable=true
