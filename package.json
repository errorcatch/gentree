{
  "name": "gentree",
  "version": "0.1.0",
  "description": "generate a rojo project tree, live",
  "type": "module",
  "bin": {
    "gentree": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --target=node22 --format=cjs --outfile=build/gentree.cjs",
    "exe": "npm run bundle && pkg build/gentree.cjs --targets node22-win-x64 --output bin/gentree.exe",
    "exe:all": "npm run bundle && pkg build/gentree.cjs --targets node22-win-x64,node22-macos-x64,node22-macos-arm64,node22-linux-x64 --out-path bin",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rojo",
    "roblox",
    "luau",
    "codegen"
  ],
  "author": "",
  "license": "GPL 3.0",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  }
}
